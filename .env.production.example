NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace_with_very_strong_secret
PUBLIC_PATH=public

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Seed hardening for production
SEED_ENDPOINT_ENABLED=false
SEED_TRIGGER_KEY=
SEED_INCLUDE_DEMO_USERS=false
SEED_DEMO_PASSWORD=unused_in_production

# Initial admin bootstrap (required for bootstrap:admin)
SEED_ADMIN_EMAIL=admin@your-company.com
SEED_ADMIN_PASSWORD=replace_with_strong_admin_password
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Principal
SEED_ADMIN_RESET_PASSWORD=false
