# ==========================================================================
#  BACKEND — ENTORNO DE PRODUCCIÓN (Render)
# --------------------------------------------------------------------------
#  Estas son las variables para COMPLETAR al desplegar en Render.
#  Cárgalas en el dashboard de Render (Environment) del servicio backend.
#  NO subas este archivo con valores reales a git.
# ==========================================================================

# --- App ---
NODE_ENV=production
# PORT lo asigna Render automáticamente; no hace falta definirlo.
PUBLIC_PATH=public

# --- Base de datos (Postgres de Render → Internal Database URL) ---
DATABASE_URL=

# --- Seguridad ---
# Secreto fuerte y único. Genera con:  openssl rand -base64 48
JWT_SECRET=
# Orígenes permitidos (coma-separado): URLs de admin y marketplace en Render.
CORS_ORIGINS=https://admin-XXXX.onrender.com,https://marketplace-XXXX.onrender.com

# --- Cloudinary (imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Seed: endurecido para producción (dejar así) ---
SEED_ENDPOINT_ENABLED=false
SEED_TRIGGER_KEY=
SEED_INCLUDE_DEMO_USERS=false
SEED_INCLUDE_PRODUCTS=false
SEED_DEMO_PASSWORD=unused_in_production

# --- Admin inicial (lo crea bootstrap:admin en el primer arranque) ---
SEED_ADMIN_EMAIL=admin@tu-empresa.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Principal
SEED_ADMIN_RESET_PASSWORD=false

# ==========================================================================
#  SUNAT — Producción
# --------------------------------------------------------------------------
#  En prod los datos del emisor (RUC, certificado .pfx, Clave SOL) se cargan
#  CIFRADOS desde el dashboard, no por env. Aquí solo va la llave maestra.
# ==========================================================================
# Llave AES-256-GCM que cifra los secretos SUNAT en la BD.
# Genera con:  openssl rand -base64 32
# ⚠️ Debe ser FIJA. Si la cambias, los secretos ya guardados se vuelven ilegibles.
SUNAT_CONFIG_ENC_KEY=
