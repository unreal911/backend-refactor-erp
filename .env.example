PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=replace_with_a_strong_secret
PUBLIC_PATH=public
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NODE_ENV=production
SEED_ENDPOINT_ENABLED=false
SEED_TRIGGER_KEY=define_if_you_need_manual_seed_key
SEED_INCLUDE_DEMO_USERS=true
SEED_DEMO_PASSWORD=password123
SEED_ADMIN_EMAIL=admin@tu-dominio.com
SEED_ADMIN_PASSWORD=super_segura
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Principal
SEED_ADMIN_RESET_PASSWORD=false

# ===== SUNAT Facturacion electronica (entorno BETA de pruebas) =====
# RUC del emisor. Por defecto 20100066603 (RUC de pruebas de la documentacion).
SUNAT_RUC=20100066603
SUNAT_RAZON_SOCIAL=EMISOR DEMO SAC
# Ubigeo del domicilio fiscal del emisor (6 digitos, catalogo INEI). Def: 150101 (Lima).
SUNAT_UBIGEO=150101
# Credenciales de la Clave SOL (en beta: usuario MODDATOS / clave MODDATOS).
SUNAT_BETA_SOL_USER=MODDATOS
SUNAT_BETA_SOL_PASSWORD=MODDATOS
SUNAT_BETA_ENDPOINT=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService
# Firma: beta NO exige certificado real. Con ALLOW_TEST_CERT se autofirma.
SUNAT_ALLOW_TEST_CERT=true
SUNAT_SIGNATURE_ID=SignSUNAT
# Produccion (dejar vacios en beta): certificado digital registrado en SUNAT.
# SUNAT_CERT_P12_PATH=cert/certificado.p12
# SUNAT_CERT_P12_PASSWORD=clave-del-certificado
# SUNAT_CERT_PEM_PATH=cert/cert.pem
# SUNAT_KEY_PEM_PATH=cert/key.pem
