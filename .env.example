# ==========================================================================
#  BACKEND — ENTORNO DE PRUEBAS / DESARROLLO LOCAL
# --------------------------------------------------------------------------
#  Copia este archivo a  .env  y ajusta lo que necesites.
#  Valores pensados para correr local + SUNAT en BETA (no producción).
#  Para producción usa  .env.production.example
# ==========================================================================

# --- App ---
NODE_ENV=development
PORT=3000
PUBLIC_PATH=public

# --- Base de datos (Postgres local) ---
DATABASE_URL=postgresql://user:password@localhost:5432/tienda_dbt

# --- Seguridad ---
JWT_SECRET=replace_with_a_strong_secret
# CORS: vacío = permite todos (cómodo en local). En prod restríngelo.
CORS_ORIGINS=

# --- Cloudinary (imágenes) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Seed / datos demo (OK activarlos en local) ---
SEED_ENDPOINT_ENABLED=true
SEED_TRIGGER_KEY=define_if_you_need_manual_seed_key
SEED_INCLUDE_DEMO_USERS=true
SEED_INCLUDE_PRODUCTS=true
SEED_DEMO_PASSWORD=password123
SEED_ADMIN_EMAIL=admin@dominio.com
SEED_ADMIN_PASSWORD=supersegura
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Principal
SEED_ADMIN_RESET_PASSWORD=false

# ==========================================================================
#  SUNAT — Facturación electrónica en BETA (pruebas)
# --------------------------------------------------------------------------
#  En BETA el emisor se puede configurar por estas env (fallback).
#  En PRODUCCIÓN NO: los datos reales del emisor (RUC, certificado, Clave SOL)
#  se cargan cifrados desde el dashboard; solo hace falta SUNAT_CONFIG_ENC_KEY.
# ==========================================================================
# Llave maestra para cifrar/descifrar secretos SUNAT en la BD (AES-256-GCM).
# Genérala con:  openssl rand -base64 32
# NO la cambies una vez guardados secretos (los vuelve irrecuperables).
SUNAT_CONFIG_ENC_KEY=

# Emisor de pruebas (RUC de la documentación oficial SUNAT).
SUNAT_RUC=20100066603
SUNAT_RAZON_SOCIAL=EMISOR DEMO SAC
SUNAT_UBIGEO=150101

# Clave SOL de beta (usuario/clave estándar de pruebas).
SUNAT_BETA_SOL_USER=MODDATOS
SUNAT_BETA_SOL_PASSWORD=MODDATOS
SUNAT_BETA_ENDPOINT=https://e-beta.sunat.gob.pe/ol-ti-itcpfegem-beta/billService

# Firma: en beta no exige certificado real; autofirma con cert de prueba.
SUNAT_ALLOW_TEST_CERT=true
SUNAT_SIGNATURE_ID=SignSUNAT
